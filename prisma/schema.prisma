generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  priority    String
  status      String
  sprint      String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())
}
